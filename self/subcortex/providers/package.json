{
  "name": "@nous/subcortex-providers",
  "version": "0.0.1",
  "private": true,
  "description": "Model provider implementations for Nous-OSS — Ollama, Chat Completions, and Anthropic",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.js",
      "default": "./dist/adapters/index.js"
    },
    "./adapters/output": {
      "types": "./dist/adapters/output.d.ts",
      "import": "./dist/adapters/output.js",
      "require": "./dist/adapters/output.js",
      "default": "./dist/adapters/output.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nous/shared": "workspace:*",
    "@nous/autonomic-config": "workspace:*",
    "zod": "^3.24.1"
  }
}
