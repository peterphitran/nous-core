{
  "name": "nous-oss",
  "version": "0.0.0",
  "private": true,
  "description": "Neural Operations Unification System — an open-core AI agent operating system modeled on the structure of the human mind",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "check:generated": "pnpm --filter @nous/subcortex-providers run check:generated",
    "lint": "oxlint self/",
    "format": "oxlint --fix self/",
    "test": "vitest run --pool threads",
    "test:watch": "vitest --pool threads",
    "benchmark:tier0": "pnpm --filter nous-benchmark run test",
    "dev:web": "pnpm --filter @nous/web dev",
    "dev:desktop": "pnpm --filter @nous/desktop dev",
    "build:desktop": "pnpm --filter @nous/desktop build",
    "dev:cli": "pnpm --filter @nous/cli run dev --",
    "dev:docs": "pnpm --filter docs dev",
    "install:nous": "node scripts/install/run.mjs",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@oxlint/binding-win32-x64-msvc": "^1.47.0",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.0",
    "oxlint": "^1.47.0",
    "tsdown": "^0.20.3",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "electron",
      "koffi",
      "unrs-resolver"
    ]
  }
}
